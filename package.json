{
    "name": "tally-dekho",
    "version": "1.0.42",
    "main": "main.js",
    "description": "TallyDekho Connector",
    "author": "Alcodes Mobility Pvt Ltd",
    "private": true,
    "scripts": {
        "react": "npm run dev --prefix renderer",
        "electron": "cross-env ELECTRON_DEV=1 electronmon .",
        "dev": "concurrently \"npm run react\" \"npm run electron\"",
        "build": "npm run build --prefix renderer && electron-builder",
        "postinstall": "electron-builder install-app-deps",
        "dist": "electron-builder"
    },
    "build": {
        "appId": "com.alcodes.tallydekho",
        "productName": "TallyDekho",
        "directories": {
            "output": "dist_electron",
            "buildResources": "build"
        },
        "files": [
            "main.js",
            "package.json",
            "preload.js",
            "util/**",
            "xmls/**",
            {
                "from": "renderer/dist",
                "to": "renderer/dist",
                "filter": [
                    "**/*"
                ]
            },
            "!node_modules/7zip-bin/linux/**",
            "!node_modules/7zip-bin/mac/**",
            "!node_modules/7zip-bin/win/ia32/**",
            "!node_modules/7zip-bin/win/arm64/**"
        ],
        "publish": [
            {
                "provider": "generic",
                "url": "https://test.tallydekho.com/tallydekho/"
            }
        ],
        "asar": true,
        "asarUnpack": [
            "node_modules/7zip-bin/**"
        ],
        "compression": "maximum",
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "build/icon.ico",
            "signExts": [
                ".exe",
                ".dll"
            ],
            "signtoolOptions": {
                "signingHashAlgorithms": [
                    "sha256"
                ],
                "certificateSha1": "2B1CA02CE1BB9B915F19492273341E6744E1F80A",
                "rfc3161TimeStampServer": "http://timestamp.sectigo.com",
                "publisherName": [
                    "CN=ALCODES MOBILITY PRIVATE LIMITED, O=ALCODES MOBILITY PRIVATE LIMITED, S=Rajasthan, C=IN"
                ]
            }
        },
        "nsis": {
            "artifactName": "${productName}-${version}.${ext}",
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "perMachine": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "TallyDekho",
            "runAfterFinish": true,
            "installerIcon": "build/icon2.ico",
            "uninstallerIcon": "build/icon2.ico",
            "deleteAppDataOnUninstall": true,
            "differentialPackage": true,
            "allowElevation": true,
            "license": "build/license.rtf"
        },
        "extraResources": [
            {
                "from": "build/icon.png",
                "to": "build/icon.png",
                "filter": [
                    "**/*"
                ]
            }
        ]
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "cross-env": "^10.0.0",
        "electron": "^37.4.0",
        "electron-builder": "^26.0.12",
        "electronmon": "^2.0.3"
    },
    "dependencies": {
        "7zip-bin": "^5.2.0",
        "ajv": "^8.17.1",
        "ajv-formats": "^3.0.1",
        "axios": "^1.12.2",
        "child_process": "^1.0.2",
        "electron-log": "^5.4.3",
        "electron-store": "^8.2.0",
        "electron-updater": "^6.6.2",
        "fast-xml-parser": "^5.2.5",
        "form-data": "^4.0.4",
        "fs-extra": "^11.3.2",
        "got": "^14.4.9",
        "node-machine-id": "^1.1.12",
        "socket.io-client": "^4.8.1"
    }
}