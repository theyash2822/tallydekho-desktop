<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>COLLECTION</TYPE>
        <ID>Getcurrentcompany</ID>
    </HEADER>

    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION ISINITIALIZE="Yes" NAME="Getcurrentcompany">
                        <TYPE>Company</TYPE>
                        <NATIVEMETHOD>Name</NATIVEMETHOD>
                        <NATIVEMETHOD>Guid</NATIVEMETHOD>
                        <NATIVEMETHOD>_ThisYearBeg</NATIVEMETHOD>
                        <NATIVEMETHOD>_ThisYearEnd</NATIVEMETHOD>
                        <FILTERS>Svcurrent</FILTERS>
                    </COLLECTION>
                    <SYSTEM NAME="Svcurrent" ISINTERNAL="No" ISFIXED="No" ISMODIFY="No" TYPE="Formulae">
                        $Name = ##Svcurrentcompany
                    </SYSTEM>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>