<?xml version='1.0' encoding='utf-8'?>
<!-- Full ledger master: all fields including credit limit, bank details, bill-wise, TDS -->
<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Data</TYPE>
        <ID>MyReportLedgerTable</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>XML (Data Interchange)</SVEXPORTFORMAT>
                <SVCURRENTCOMPANY>$$COMPANY_NAME</SVCURRENTCOMPANY>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <REPORT NAME='MyReportLedgerTable'><FORMS>MyForm</FORMS></REPORT>
                    <FORM NAME='MyForm'><PARTS>MyPart01</PARTS></FORM>
                    <PART NAME='MyPart01'>
                        <LINES>MyLine01</LINES>
                        <REPEAT>MyLine01 : MyCollection</REPEAT>
                        <SCROLLED>Vertical</SCROLLED>
                    </PART>
                    <LINE NAME='MyLine01'>
                        <FIELDS>Fld01,Fld02,Fld03,Fld04,Fld05,Fld06,Fld07,Fld08,Fld09,Fld10,Fld11,Fld12,Fld13,Fld14,Fld15,Fld16,Fld17,Fld18,Fld19,Fld20,Fld21,Fld22,Fld23,Fld24,Fld25</FIELDS>
                    </LINE>
                    <FIELD NAME='Fld01'><SET>$Guid</SET><XMLTAG>Guid</XMLTAG></FIELD>
                    <FIELD NAME='Fld02'><SET>if $$IsEmpty:$AlterId then '0' else $$String:$AlterId</SET><XMLTAG>AlterId</XMLTAG></FIELD>
                    <FIELD NAME='Fld03'><SET>$Name</SET><XMLTAG>Name</XMLTAG></FIELD>
                    <FIELD NAME='Fld04'><SET>if $$IsEqual:$Parent:$$SysName:Primary then '' else $Parent</SET><XMLTAG>Parent</XMLTAG></FIELD>
                    <FIELD NAME='Fld05'><SET>$OnlyAlias</SET><XMLTAG>Alias</XMLTAG></FIELD>
                    <FIELD NAME='Fld06'><SET>$GSTRegistrationType</SET><XMLTAG>GSTRegType</XMLTAG></FIELD>
                    <FIELD NAME='Fld07'><SET>$PartyGSTIN</SET><XMLTAG>GSTIN</XMLTAG></FIELD>
                    <FIELD NAME='Fld08'><SET>$IncomeTaxNumber</SET><XMLTAG>PAN</XMLTAG></FIELD>
                    <FIELD NAME='Fld09'><SET>$LedPhone</SET><XMLTAG>Phone</XMLTAG></FIELD>
                    <FIELD NAME='Fld10'><SET>$Email</SET><XMLTAG>Email</XMLTAG></FIELD>
                    <FIELD NAME='Fld11'><SET>$Address</SET><XMLTAG>Address</XMLTAG></FIELD>
                    <FIELD NAME='Fld12'><SET>$$StringFindAndReplace:($$String:$CreditLimit):'(-)':'-'</SET><XMLTAG>CreditLimit</XMLTAG></FIELD>
                    <FIELD NAME='Fld13'><SET>if $IsBillWiseOn then 1 else 0</SET><XMLTAG>IsBillWise</XMLTAG></FIELD>
                    <FIELD NAME='Fld14'><SET>if $IsCostCentresOn then 1 else 0</SET><XMLTAG>IsCostCentre</XMLTAG></FIELD>
                    <FIELD NAME='Fld15'><SET>if $IsRevenue then 1 else 0</SET><XMLTAG>IsRevenue</XMLTAG></FIELD>
                    <FIELD NAME='Fld16'><SET>$$StringFindAndReplace:($$String:$OpeningBalance):'(-)':'-'</SET><XMLTAG>OpeningBalance</XMLTAG></FIELD>
                    <FIELD NAME='Fld17'><SET>$$StringFindAndReplace:($$String:$ClosingBalance):'(-)':'-'</SET><XMLTAG>ClosingBalance</XMLTAG></FIELD>
                    <FIELD NAME='Fld18'><SET>$LedgerPhone</SET><XMLTAG>LedgerPhone</XMLTAG></FIELD>
                    <FIELD NAME='Fld19'><SET>$ContactPerson</SET><XMLTAG>ContactPerson</XMLTAG></FIELD>
                    <FIELD NAME='Fld20'><SET>$BankAccountDetails[1].BankName</SET><XMLTAG>BankName</XMLTAG></FIELD>
                    <FIELD NAME='Fld21'><SET>$BankAccountDetails[1].AccountNumber</SET><XMLTAG>BankAccountNo</XMLTAG></FIELD>
                    <FIELD NAME='Fld22'><SET>$BankAccountDetails[1].IFSCCode</SET><XMLTAG>IFSC</XMLTAG></FIELD>
                    <FIELD NAME='Fld23'><SET>if ($$IsEqual:$GstApplicable:($$SysName:Applicable) AND NOT $$IsEmpty:$GSTDetails[Last].Hsncode) then $GSTDetails[Last].Hsncode else ''</SET><XMLTAG>HSN</XMLTAG></FIELD>
                    <FIELD NAME='Fld24'><SET>$TDSNatureOfPayment</SET><XMLTAG>TDSNature</XMLTAG></FIELD>
                    <FIELD NAME='Fld25'><SET>$CurrencyName</SET><XMLTAG>Currency</XMLTAG></FIELD>
                    <FIELD NAME='FldBlank'><SET>''</SET></FIELD>
                    <COLLECTION NAME='MyCollection'>
                        <TYPE>Ledger</TYPE>
                        <FETCH>BankAccountDetails,GSTDetails,TDSNatureOfPayment</FETCH>
                        <FILTER>Fltr01</FILTER>
                    </COLLECTION>
                    <SYSTEM TYPE='Formulae' NAME='Fltr01'>$AlterID > $$ALTER_ID</SYSTEM>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>
