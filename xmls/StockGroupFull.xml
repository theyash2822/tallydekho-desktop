<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Collection</TYPE>
        <ID>StockGroupReport</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>XML (Data Interchange)</SVEXPORTFORMAT>
                <SVCURRENTCOMPANY>Demo2</SVCURRENTCOMPANY>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION NAME="StockGroupReport">
                        <TYPE>StockGroup</TYPE>
                        <NATIVEMETHOD>Name,Guid,ALTERID,Parent</NATIVEMETHOD>
                        <Compute>ParentGuid:$Guid:StockGroup:$Parent</Compute>
                        <Filter>Fltr01</Filter>
                    </COLLECTION>
                    <SYSTEM TYPE='Formulae' NAME='Fltr01'>$AlterId > 0</SYSTEM>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>