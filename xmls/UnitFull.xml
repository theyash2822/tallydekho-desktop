<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Collection</TYPE>
        <ID>UnitReport</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>XML (Data Interchange)</SVEXPORTFORMAT>
                <SVCURRENTCOMPANY>Demo2</SVCURRENTCOMPANY>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION NAME="UnitReport">
                        <TYPE>UNIT</TYPE>
                        <NATIVEMETHOD>Name,Guid,ALTERID,FORMALNAME,IS_SIMPLE_UNIT,BASE_UNITS,ADDITIONAL_UNITS,CONVERSION</NATIVEMETHOD>
                        <Compute>IS_SIMPLE_UNIT:$ISSIMPLEUNIT</Compute>
                        <Compute>ALTERID:if $$IsEmpty:$AlterId then '0' else $$String:$AlterId</Compute>
                        <Compute>ADDITIONAL_UNITS:$ADDITIONALUNITS</Compute>
                        <Compute>BASE_UNITS:if $$IsEmpty:$BASEUNITS then '' else $$String:$BASEUNITS</Compute>
                        <Compute>FORMAL_NAME:$FORMALNAME</Compute>
                        <Filter>Fltr01</Filter>
                    </COLLECTION>
                    <SYSTEM TYPE='Formulae' NAME='Fltr01'>$AlterId > 0</SYSTEM>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>