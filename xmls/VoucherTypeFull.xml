<ENVELOPE>
    <HEADER>
        <VERSION>1</VERSION>
        <TALLYREQUEST>Export</TALLYREQUEST>
        <TYPE>Collection</TYPE>
        <ID>VoucherTypeReport</ID>
    </HEADER>
    <BODY>
        <DESC>
            <STATICVARIABLES>
                <SVEXPORTFORMAT>XML (Data Interchange)</SVEXPORTFORMAT>
                <SVCURRENTCOMPANY>Demo2</SVCURRENTCOMPANY>
            </STATICVARIABLES>
            <TDL>
                <TDLMESSAGE>
                    <COLLECTION NAME="VoucherTypeReport">
                        <TYPE>VoucherType</TYPE>
                        <BELONGSTO>Yes</BELONGSTO>
                        <NATIVEMETHOD>Name,Guid,ALTERID,PARENT,PARENTGuid</NATIVEMETHOD>
                        <Compute>PARENTGuid:$Guid:Vouchertype:$Parent</Compute>
                        <Compute>ALTERID:if $$IsEmpty:$AlterId then '0' else $$String:$AlterId</Compute>
                        <Compute>NUMBERINGMETHOD:$NUMBERINGMETHOD</Compute>
                        <Compute>ISDEEMEDPOSITIVE:$ISDEEMEDPOSITIVE</Compute>
                        <Compute>AFFECTSSTOCK:$AFFECTSSTOCK</Compute>
                    <Filter>Fltr01</Filter>
                    </COLLECTION>
                    <SYSTEM TYPE='Formulae' NAME='Fltr01'>$AlterId > 0</SYSTEM>
                </TDLMESSAGE>
            </TDL>
        </DESC>
    </BODY>
</ENVELOPE>